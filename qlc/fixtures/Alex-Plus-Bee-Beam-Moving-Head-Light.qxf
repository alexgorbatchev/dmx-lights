 <Channel Name="Bee-white" Preset="IntensityWhite"/>
 <Channel Name="Red Laser" Preset="IntensityRed"/>
 <Channel Name="Green Laser" Preset="IntensityGreen"/>
 <Channel Name="STROB1">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="10" Preset="ShutterOpen">Shutter open</Capability>
  <Capability Min="11" Max="255" Preset="StrobeSlowToFast">Strobe slow…fast</Capability>
 </Channel>
 <Channel Name="STROB2">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="10" Preset="ShutterOpen">Shutter open</Capability>
  <Capability Min="11" Max="255" Preset="StrobeSlowToFast">Strobe slow…fast</Capability>
 </Channel>
 <Channel Name="Light Belt">
  <Group Byte="0">Effect</Group>
  <Capability Min="0" Max="9">No function</Capability>
  <Capability Min="10" Max="255">Change effect every 10 seconds</Capability>
 </Channel>
 <Channel Name="Light Belt Speed">
  <Group Byte="0">Speed</Group>
  <Capability Min="0" Max="255" Preset="SlowToFast">Effect speed slow…fast</Capability>
 </Channel>
 <Channel Name="Macro function 24ch">
  <Group Byte="0">Effect</Group>
  <Capability Min="0" Max="50">Channel 1 to Channel 23 Active</Capability>
  <Capability Min="51" Max="150">Auto run</Capability>
  <Capability Min="151" Max="250">Voice mode</Capability>
  <Capability Min="251" Max="255" Preset="ResetAll">3 second reset (hold 3s)</Capability>
 </Channel>
