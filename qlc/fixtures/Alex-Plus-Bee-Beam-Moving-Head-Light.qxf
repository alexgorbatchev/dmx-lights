<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE FixtureDefinition>
<FixtureDefinition xmlns="http://www.qlcplus.org/FixtureDefinition">
 <Creator>
  <Name>OFL – https://open-fixture-library.org/alex/plus-bee-beam-moving-head</Name>
  <Version>1.3.2</Version>
  <Author>Alex</Author>
 </Creator>
 <Manufacturer>Alex</Manufacturer>
 <Model>Plus Bee Beam Moving Head Light</Model>
 <Type>Moving Head</Type>
 <Channel Name="X Motor" Preset="PositionPan"/>
 <Channel Name="X Motor Speed" Preset="SpeedPanTiltFastSlow"/>
 <Channel Name="X Motor Slip ring">
  <Group Byte="0">Pan</Group>
  <Capability Min="0" Max="9">No function</Capability>
  <Capability Min="10" Max="127" Preset="RotationClockwiseSlowToFast">Pan CW slow…fast</Capability>
  <Capability Min="128" Max="255" Preset="RotationCounterClockwiseFastToSlow">Pan CCW fast…slow</Capability>
 </Channel>
 <Channel Name="Bee eyes rotation">
  <Group Byte="0">Speed</Group>
  <Capability Min="0" Max="128" Preset="RotationIndexed">Rotation 0…180°</Capability>
  <Capability Min="129" Max="191" Preset="RotationClockwiseSlowToFast">Rotation CW slow…fast</Capability>
  <Capability Min="192" Max="255" Preset="RotationCounterClockwiseSlowToFast">Rotation CCW slow…fast</Capability>
 </Channel>
 <Channel Name="Y-axis 1" Preset="PositionTilt"/>
 <Channel Name="Y-axis 2" Preset="PositionTilt"/>
 <Channel Name="Y-axis 3" Preset="PositionTilt"/>
 <Channel Name="Dimmer" Preset="IntensityDimmer"/>
 <Channel Name="STROB">
  <Group Byte="0">Shutter</Group>
  <Capability Min="0" Max="10" Preset="ShutterOpen">Shutter open</Capability>
  <Capability Min="11" Max="255" Preset="StrobeSlowToFast">Strobe slow…fast</Capability>
 </Channel>
 <Channel Name="Beam-red" Preset="IntensityRed"/>
 <Channel Name="Beam-green" Preset="IntensityGreen"/>
 <Channel Name="Beam-blue" Preset="IntensityBlue"/>
 <Channel Name="Beam-white" Preset="IntensityWhite"/>
 <Channel Name="Bee-red" Preset="IntensityRed"/>
