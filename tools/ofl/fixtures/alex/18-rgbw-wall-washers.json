        "Auxiliary Light White Dimming",
        "White1 Auxiliary Light Dimming",
        "White2 Auxiliary Light Dimming",
        "White3 Auxiliary Light Dimming",
        "White4 Auxiliary Light Dimming",
        "White5 Auxiliary Light Dimming",
        "White6 Auxiliary Light Dimming",
