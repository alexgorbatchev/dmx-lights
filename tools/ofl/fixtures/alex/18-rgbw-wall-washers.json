    },
    {
      "name": "37 Channel",
      "shortName": "37ch",
      "channels": [
        {
          "insert": "matrixChannels",
          "repeatFor": ["1", "2", "3", "4", "5", "6"],
          "channelOrder": "perPixel",
          "templateChannels": ["R$pixelKey", "G$pixelKey", "B$pixelKey", "W$pixelKey"]
        },
        "White1 Auxiliary Light Dimming",
        "White2 Auxiliary Light Dimming",
        "White3 Auxiliary Light Dimming",
        "White4 Auxiliary Light Dimming",
        "White5 Auxiliary Light Dimming",
        "White6 Auxiliary Light Dimming",
        "White7 Auxiliary Light Dimming",
        "White8 Auxiliary Light Dimming",
        "White9 Auxiliary Light Dimming",
        "White10 Auxiliary Light Dimming",
